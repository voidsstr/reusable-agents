  "category": "ops",
  "task_type": "desktop-task",
  "cron_expr": "*/15 * * * *",
  "timezone": "UTC",
  "enabled": true,
  "runbook": "",
  "skill": "SKILL.md",
  "entry_command": "RESPONDER_CONFIG=$HOME/.reusable-agents/responder/config.yaml PYTHONPATH=/home/voidsstr/development/reusable-agents python3 /home/voidsstr/development/reusable-agents/agents/responder-agent/agent.py",
  "routine_id": "",
  "trigger_url": "",
  "trigger_token_env": ""
}
