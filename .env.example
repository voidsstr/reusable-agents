# reusable-agents framework — environment configuration
# Copy this to .env and fill in. Then `docker compose up -d --build`.

# ── API auth ────────────────────────────────────────────────────────────────
# Token clients send as `Authorization: Bearer <token>`. Required in
# production. If unset, the API runs with auth DISABLED (dev-mode warning).
# Generate a strong one with: openssl rand -hex 32
FRAMEWORK_API_TOKEN=

# Comma-separated list of CORS origins, or '*' for permissive (default).
# Pin to your nsc-dashboard origin for production.
FRAMEWORK_API_CORS=*

# ── Storage backend ─────────────────────────────────────────────────────────
# 'azure' (default if AZURE_STORAGE_CONNECTION_STRING is set) or 'local'.
STORAGE_BACKEND=azure

# Azure Storage Account connection string. Get it from:
#   az storage account show-connection-string --name <account> --query connectionString -o tsv
AZURE_STORAGE_CONNECTION_STRING=

# Container name (created on first run if missing). Default: 'agents'.
AZURE_STORAGE_CONTAINER=agents

# Local-storage fallback path (only used when STORAGE_BACKEND=local).
AGENT_STORAGE_LOCAL_PATH=/data/agents

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── WebSocket cadence ───────────────────────────────────────────────────────
# How often the API polls storage for status changes to push to UI clients.
# Status writes from agents are throttled to ~1/s, so this can be tighter
# than 1.0s without missing updates.
WS_POLL_INTERVAL_S=2.0

# ── UI build ────────────────────────────────────────────────────────────────
# What origin the UI bundle should hit for API calls. Leave blank if you
# put the API and UI behind the same hostname / reverse-proxy.
VITE_API_BASE_URL=http://localhost:8090
