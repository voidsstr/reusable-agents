# reusable-agents framework — environment configuration
# Copy this to .env and fill in. Then `docker compose up -d --build`.

# ── API auth ────────────────────────────────────────────────────────────────
# Two auth modes — either or both can be enabled. If neither is set, the API
# runs with auth DISABLED (dev-only).
#
# Mode 1: Bearer token (for service-to-service calls — register-agents.sh,
# host-worker, agents posting status). Generate with: openssl rand -hex 32
FRAMEWORK_API_TOKEN=

# Mode 2: Google OAuth 2.0 (for interactive humans). Sets a signed session
# cookie when an allowed user signs in via Google. The user's email must
# appear in ALLOWED_EMAILS (comma-separated, lowercase preferred).
# Create the OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to register: <PUBLIC_BASE_URL>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_EMAILS=

# 32+ random bytes used to sign the session cookie. Required when OAuth is
# enabled. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public-facing https URL of this deployment (used to build the Google
# redirect URI). Required behind any TLS-terminating proxy (Container Apps,
# nginx, Cloudflare). Example: https://agents.example.com
PUBLIC_BASE_URL=

# Comma-separated list of CORS origins, or '*' for permissive (default).
# Pin to your nsc-dashboard origin for production.
FRAMEWORK_API_CORS=*

# ── Storage backend ─────────────────────────────────────────────────────────
# 'azure' (default if AZURE_STORAGE_CONNECTION_STRING is set) or 'local'.
STORAGE_BACKEND=azure

# Azure Storage Account connection string. Get it from:
#   az storage account show-connection-string --name <account> --query connectionString -o tsv
AZURE_STORAGE_CONNECTION_STRING=

# Container name (created on first run if missing). Default: 'agents'.
AZURE_STORAGE_CONTAINER=agents

# Local-storage fallback path (only used when STORAGE_BACKEND=local).
AGENT_STORAGE_LOCAL_PATH=/data/agents

# ── Claude CLI ──────────────────────────────────────────────────────────────
# Override the `claude` binary used by the claude-cli AI provider.
# Set to a round-robin wrapper (e.g. ~/bin/claude-rr) to spread calls
# across 2 Claude Max accounts and avoid per-account rate limits.
# See ~/bin/claude-rr for setup instructions (account 2 needs a separate
# HOME dir: mkdir ~/.claude-account2-home && HOME=~/.claude-account2-home claude auth login).
#CLAUDE_CLI_CMD=claude-rr

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── WebSocket cadence ───────────────────────────────────────────────────────
# How often the API polls storage for status changes to push to UI clients.
# Status writes from agents are throttled to ~1/s, so this can be tighter
# than 1.0s without missing updates.
WS_POLL_INTERVAL_S=2.0

# ── UI build ────────────────────────────────────────────────────────────────
# What origin the UI bundle should hit for API calls. Leave blank if you
# put the API and UI behind the same hostname / reverse-proxy.
VITE_API_BASE_URL=http://localhost:8090
