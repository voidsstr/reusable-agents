# GlitchTip local config.
# Generate a 50-char secret: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
GLITCHTIP_SECRET_KEY=
GLITCHTIP_DB_PASSWORD=glitchtip
GLITCHTIP_DOMAIN=http://localhost:8095
GLITCHTIP_FROM_EMAIL=glitchtip@localhost
# consolemail:// logs outbound to container stdout (fine for single-operator boxes).
# For real outbound mail: smtp+tls://user:pass@host:587
GLITCHTIP_EMAIL_URL=consolemail://
